<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Калькулятор</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="calculator">
        <div class="input-container">
            <input type="text" id="num1" placeholder="Введите первое число">
            <input type="text" id="num2" placeholder="Введите второе число">
        </div>
        
        <div class="buttons-container">
            <button onclick="calculate('add')">Сумма</button>
            <button onclick="calculate('subtract')">Разность</button>
            <button onclick="calculate('multiply')">Произведение</button>
            <button onclick="calculate('divide')">Деление</button>
        </div>
        
        <div class="result-container">
            <div id="result"></div>
        </div>
    </div>
    
    <script src="script.js"></script>
</body>
</html>
styles.css
css
body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: linear-gradient(135deg, #6A0DAD, #FF6B6B);
    margin: 0;
}

.calculator {
    background: rgba(255, 255, 255, 0.9);
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
    width: 300px;
}

.input-container, .buttons-container {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 20px;
}

input {
    padding: 10px;
    border: 1px solid #ccc;
    border-radius: 5px;
    font-size: 16px;
}

button {
    padding: 10px 15px;
    background: #FFD1DC;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-size: 16px;
    transition: background 0.3s;
}

button:hover {
    background: #FF7979;
}

.result-container {
    text-align: center;
    font-size: 18px;
    color: #333;
}
script.js
javascript
function getNumbers() {
    const num1 = document.getElementById('num1').value;
    const num2 = document.getElementById('num2').value;
    
    if (isNaN(num1) || isNaN(num2)) {
        return { error: true, message: 'Пожалуйста, введите только числа' };
    }
    
    return { error: false, num1: parseFloat(num1), num2: parseFloat(num2) };
}

function add(a, b) {
    return a + b;
}

function subtract(a, b) {
    return a - b;
}

function multiply(a, b) {
    return a * b;
}

function divide(a, b) {
    if (b === 0) return 'Ошибка: деление на ноль';
    return a / b;
}

