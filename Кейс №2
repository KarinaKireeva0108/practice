<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Счетчик</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="counter-container">
        <div class="display" id="display">0</div>
        <div class="buttons">
            <button id="plus">+</button>
            <button id="minus">-</button>
        </div>
        <div class="message" id="message"></div>
    </div>
    <script src="script.js"></script>
</body>
</html>

body {
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: linear-gradient(45deg, #FF6B6B, #6A0DAD);
}

.counter-container {
    text-align: center;
    background: rgba(255, 255, 255, 0.1);
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
}

.display {
    font-size: 3rem;
    margin: 20px 0;
    padding: 10px;
    border-radius: 5px;
    transition: background 0.3s;
}

.buttons {
    display: flex;
    gap: 20px;
}

button {
    padding: 15px 30px;
    font-size: 1.2rem;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    background: linear-gradient(45deg, #FFD1DC, #B565FF);
    transition: opacity 0.3s;
}

button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.message {
    margin-top: 20px;
    font-size: 1.2rem;
    color: white;
}


let counter = 0;
const display = document.getElementById('display');
const plusButton = document.getElementById('plus');
const minusButton = document.getElementById('minus');
const message = document.getElementById('message');

function updateDisplay() {
    display.textContent = counter;
    
    // Смена цвета фона в зависимости от значения
    if (counter > 0) {
        display.style.background = 'yellow';
    } else if (counter < 0) {
        display.style.background = 'green';
    } else {
        display.style.background = 'red';
    }
    
    // Проверка на экстремальные значения
    if (counter === 10) {
        plusButton.disabled = true;
        message.textContent = 'Вы достигли экстремального значения';
    } else if (counter === -10) {
        minusButton.disabled = true;
        message.textContent = 'Вы достигли экстремального значения';
    } else {
        plusButton.disabled = false;
        minusButton.disabled = false;
        message.textContent = '';
    }
}

plusButton.addEventListener('click', () => {
    counter++;
    updateDisplay();
});

minusButton.addEventListener('click', () => {
    counter--;
    updateDisplay();
});

// Инициализация отображения
updateDisplay();



