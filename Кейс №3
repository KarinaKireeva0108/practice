from django.db import models

class UserName(models.Model):
    name = models.CharField(max_length=100)

    def __str__(self):
        return self.name

from django import forms
from .models import UserName

class NameForm(forms.ModelForm):
    class Meta:
        model = UserName
        fields = ['name']
        widgets = {
            'name': forms.TextInput(attrs={'class': 'form-control'})
        }

from django.shortcuts import render, redirect
from .forms import NameForm
from .models import UserName

def index(request):
    if request.method == 'POST':
        form = NameForm(request.POST)
        if form.is_valid():
            name = form.cleaned_data['name']
            if not name:
                return render(request, 'greetings/index.html', {'form': form, 'error': 'Введите имя'})
            
            # Сохраняем в базу данных
            UserName.objects.create(name=name)
            return render(request, 'greetings/index.html', {'name': name})
    else:
        form = NameForm()
    
    return render(request, 'greetings/index.html', {'form': form})

